---
import SystemDiagram from './SystemDiagram.astro';
---

<section class="relative overflow-hidden">
  <div class="mx-auto max-w-5xl px-6 pt-20 pb-12 sm:pt-28 sm:pb-16 text-center">
    <div class="mx-auto max-w-2xl fade-up">
      <p class="font-mono text-[11px] font-medium tracking-[0.14em] uppercase mb-4" style="color: var(--accent);">
        Systems Modeling Toolkit
      </p>
      <h1 class="font-serif text-[1.8rem] sm:text-[2.1rem] leading-[1.12] font-normal italic mb-5" style="color: var(--ink);">
        Model any system as bounded entities and the flows between them.
      </h1>
      <p class="font-sans text-[15px] sm:text-base leading-relaxed mb-8 mx-auto max-w-lg" style="color: var(--ink-dim);">
        Define components, wire flows across boundaries, decompose recursively, simulate dynamics.
      </p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a
          href="https://app.bert.systems"
          class="inline-flex items-center px-5 py-2.5 rounded-md font-sans text-sm font-medium text-white transition-all hover:opacity-90"
          style="background: var(--accent);"
        >
          Launch Web App
        </a>
        <a
          href="https://bert.gitbook.io"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-5 py-2.5 rounded-md font-sans text-sm font-medium transition-all border"
          style="color: var(--ink); border-color: var(--border);"
        >
          Read the Docs
        </a>
      </div>
      <a href="https://bert.gitbook.io/bert/for-researchers/system-ontology" target="_blank" rel="noopener noreferrer" class="link-hover font-sans text-xs mt-4 inline-block" style="color: var(--accent);">
        Read the full ontology &rarr;
      </a>

      <div class="mt-3 flex justify-center" style="color: var(--ink); opacity: 0.15;">
        <svg class="w-4 h-4 scroll-cue" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path d="M19 9l-7 7-7-7" />
        </svg>
      </div>
    </div>

    <div class="mt-10 mx-auto max-w-2xl fade-up" style="animation-delay: 0.15s;">
      <SystemDiagram />
    </div>
  </div>
</section>
