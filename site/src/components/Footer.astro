  <div class="mx-auto max-w-5xl px-6 flex items-center justify-between">
    <a href="https://halcyonic.systems" target="_blank" rel="noopener noreferrer" class="link-hover font-serif text-sm italic" style="color: var(--ink-dim);">
      A Halcyonic Systems project &rarr;
    </a>
    <span class="font-sans text-xs" style="color: var(--ink-dim); opacity: 0.4;">
      &copy; {year} Halcyonic Systems
    </span>
  </div>
</footer>
