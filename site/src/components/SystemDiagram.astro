---
---

<div class="relative rounded-2xl overflow-hidden p-5 sm:p-8 border" style="background: var(--canvas); border-color: color-mix(in srgb, var(--accent) 15%, transparent);">
  <svg id="system-diagram" viewBox="0 0 700 280" xmlns="http://www.w3.org/2000/svg" class="w-full" style="max-height: 280px;">
    <defs>
      <marker id="ah" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
        <polygon points="0 0, 8 3, 0 6" fill="var(--accent)" opacity="0.7" />
      </marker>
      <marker id="ah-dim" markerWidth="6" markerHeight="5" refX="5" refY="2.5" orient="auto">
        <polygon points="0 0, 6 2.5, 0 5" fill="var(--accent)" opacity="0.4" />
      </marker>
    </defs>

    <!-- Source -->
    <rect x="10" y="115" width="80" height="40" rx="4" fill="none" stroke="var(--ink)" stroke-width="1.2" opacity="0.3" />
    <text x="50" y="140" text-anchor="middle" font-family="Inter" font-size="11" fill="var(--ink)" opacity="0.5">Source</text>

    <!-- Source → A -->
    <line x1="90" y1="135" x2="178" y2="135" stroke="var(--accent)" stroke-width="1.5" marker-end="url(#ah)" opacity="0.45" />
    <text class="flow-label" x="134" y="127" text-anchor="middle" font-family="JetBrains Mono" font-size="9" fill="var(--accent)" style="display: none;">Energy</text>

    <!-- Entity A -->
    <g id="entity-a" class="cursor-pointer" role="button" tabindex="0" aria-label="Advance diagram">
      <circle id="ea-circle" cx="255" cy="135" r="68" fill="var(--card-bg)" stroke="var(--ink)" stroke-width="1.5" />
      <text id="ea-label" x="255" y="132" text-anchor="middle" font-family="Cormorant Garamond" font-size="17" font-style="italic" fill="var(--ink)">Entity A</text>
      <text id="ea-sublabel" x="255" y="150" text-anchor="middle" font-family="JetBrains Mono" font-size="9" fill="var(--ink)" opacity="0.25">bounded</text>
    </g>

    <!-- Decomposed (stage 2) -->
    <g id="decomposed" style="display: none;">
      <circle cx="255" cy="135" r="68" fill="none" stroke="var(--ink)" stroke-width="1.5" stroke-dasharray="5 3" opacity="0.4" />
      <circle cx="232" cy="112" r="24" fill="var(--card-bg)" stroke="var(--ink)" stroke-width="1.2" />
      <text x="232" y="109" text-anchor="middle" font-family="Inter" font-size="10" font-weight="500" fill="var(--ink)">Sub A.1</text>
      <text x="232" y="122" text-anchor="middle" font-family="JetBrains Mono" font-size="8" fill="var(--accent)">T</text>
      <circle cx="278" cy="158" r="24" fill="var(--card-bg)" stroke="var(--ink)" stroke-width="1.2" />
      <text x="278" y="155" text-anchor="middle" font-family="Inter" font-size="10" font-weight="500" fill="var(--ink)">Sub A.2</text>
      <text x="278" y="168" text-anchor="middle" font-family="JetBrains Mono" font-size="8" fill="var(--accent)">H</text>
      <line x1="248" y1="128" x2="264" y2="144" stroke="var(--accent)" stroke-width="1.2" marker-end="url(#ah-dim)" opacity="0.5" />
    </g>

    <!-- A → B -->
    <line x1="323" y1="135" x2="388" y2="135" stroke="var(--accent)" stroke-width="1.5" marker-end="url(#ah)" opacity="0.45" />
    <text class="flow-label" x="355" y="127" text-anchor="middle" font-family="JetBrains Mono" font-size="9" fill="var(--accent)" style="display: none;">Message</text>

    <!-- Entity B -->
    <circle cx="455" cy="135" r="58" fill="var(--card-bg)" stroke="var(--ink)" stroke-width="1.5" />
    <text x="455" y="132" text-anchor="middle" font-family="Cormorant Garamond" font-size="17" font-style="italic" fill="var(--ink)">Entity B</text>
    <text x="455" y="150" text-anchor="middle" font-family="JetBrains Mono" font-size="9" fill="var(--ink)" opacity="0.25">bounded</text>

    <!-- B → Sink -->
    <line x1="513" y1="135" x2="598" y2="135" stroke="var(--accent)" stroke-width="1.5" marker-end="url(#ah)" opacity="0.45" />
    <text class="flow-label" x="555" y="127" text-anchor="middle" font-family="JetBrains Mono" font-size="9" fill="var(--accent)" style="display: none;">Product</text>

    <!-- Sink -->
    <rect x="600" y="115" width="80" height="40" rx="4" fill="none" stroke="var(--ink)" stroke-width="1.2" opacity="0.3" />
    <text x="640" y="140" text-anchor="middle" font-family="Inter" font-size="11" fill="var(--ink)" opacity="0.5">Sink</text>
  </svg>

  <!-- Stepper -->
  <div class="flex items-center justify-center gap-4 mt-4">
    <div class="flex gap-2" id="stepper-dots">
      <button class="w-2.5 h-2.5 rounded-full transition-all cursor-pointer stepper-dot dot-pulse" data-step="0" style="background: var(--accent);" aria-label="Step 1: Define entities"></button>
      <button class="w-2.5 h-2.5 rounded-full transition-all cursor-pointer stepper-dot" data-step="1" style="background: var(--ink); opacity: 0.15;" aria-label="Step 2: Type the flows"></button>
      <button class="w-2.5 h-2.5 rounded-full transition-all cursor-pointer stepper-dot" data-step="2" style="background: var(--ink); opacity: 0.15;" aria-label="Step 3: Decompose recursively"></button>
    </div>
    <span id="stepper-label" class="font-serif text-sm italic" style="color: var(--ink-dim);">
      Define entities
    </span>
  </div>
</div>

<script>
  let stage = 0;
  const labels = ['Define entities', 'Type the flows', 'Decompose recursively'];
  setTimeout(() => document.querySelector('.dot-pulse')?.classList.remove('dot-pulse'), 3000);
  const circle = document.getElementById('ea-circle')!;
  const eaLabel = document.getElementById('ea-label')!;
  const eaSub = document.getElementById('ea-sublabel')!;
  const decomposed = document.getElementById('decomposed')!;
  const flowLabels = document.querySelectorAll('.flow-label');
  const stepLabel = document.getElementById('stepper-label')!;
  const dots = document.querySelectorAll('.stepper-dot');

  function setStage(s: number) {
    stage = s;
    stepLabel.textContent = labels[s];
    dots.forEach((d, i) => {
      (d as HTMLElement).style.background = i === s ? 'var(--accent)' : 'var(--ink)';
      (d as HTMLElement).style.opacity = i === s ? '1' : '0.15';
    });

    // Stage 0: just entities
    flowLabels.forEach(l => (l as SVGElement).style.display = s >= 1 ? '' : 'none');

    // Stage 2: decompose
    if (s >= 2) {
      circle.setAttribute('stroke-dasharray', '5 3');
      circle.style.opacity = '0.4';
      eaLabel.style.display = 'none';
      eaSub.style.display = 'none';
      decomposed.style.display = '';
    } else {
      circle.removeAttribute('stroke-dasharray');
      circle.style.opacity = '1';
      eaLabel.style.display = '';
      eaSub.style.display = '';
      decomposed.style.display = 'none';
    }
  }

  document.getElementById('entity-a')?.addEventListener('click', () => {
    setStage((stage + 1) % 3);
  });

  document.getElementById('entity-a')?.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
      e.preventDefault();
      setStage((stage + 1) % 3);
    }
  });

  dots.forEach(d => {
    d.addEventListener('click', () => {
      setStage(parseInt((d as HTMLElement).dataset.step || '0'));
    });
  });
</script>
